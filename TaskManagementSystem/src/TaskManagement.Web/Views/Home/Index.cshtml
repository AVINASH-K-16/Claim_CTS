@{
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>Welcome to Task Management System</h1>
            <p class="lead">This is a beginner-friendly Clean Architecture project that demonstrates:</p>
            
            <ul>
                <li><strong>Domain Layer:</strong> Business entities and rules</li>
                <li><strong>Application Layer:</strong> Services and business logic</li>
                <li><strong>Infrastructure Layer:</strong> Database access</li>
                <li><strong>Presentation Layers:</strong> API and Web interfaces</li>
            </ul>

            <a href="/Task" class="btn btn-primary btn-lg mt-4">Go to Task Management</a>
        </div>
    </div>
</div>
