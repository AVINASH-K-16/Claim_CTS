@model TaskManagement.Web.ViewModels.TaskFormViewModel

@{
    ViewData["Title"] = Model.IsEditMode ? "Edit Task" : "Create Task";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>@ViewData["Title"]</h1>

            <form asp-action="@(Model.IsEditMode ? "Edit" : "Create")" method="post" class="mt-4">
                <div asp-validation-summary="All" class="alert alert-danger"></div>

                @if (Model.IsEditMode)
                {
                    <input type="hidden" asp-for="Id" />
                }

                <div class="mb-3">
                    <label asp-for="Title" class="form-label">Title *</label>
                    <input type="text" asp-for="Title" class="form-control" required />
                    <small class="text-muted">Must be 3-200 characters</small>
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <small class="text-muted">Max 1000 characters</small>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                @if (Model.IsEditMode)
                {
                    <div class="mb-3">
                        <div class="form-check">
                            <input type="checkbox" asp-for="IsCompleted" class="form-check-input" />
                            <label asp-for="IsCompleted" class="form-check-label">Mark as Completed</label>
                        </div>
                    </div>
                }

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        @(Model.IsEditMode ? "Update" : "Create") Task
                    </button>
                    <a href="@Url.Action("Index", "Task")" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
