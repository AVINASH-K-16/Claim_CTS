@model TaskManagement.Application.DTOs.TaskDto

@{
    ViewData["Title"] = "Task Details";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>@Model.Title</h1>
            
            <div class="card">
                <div class="card-body">
                    <p><strong>ID:</strong> @Model.Id</p>
                    <p><strong>Description:</strong></p>
                    <p>@(string.IsNullOrEmpty(Model.Description) ? "No description" : Model.Description)</p>
                    
                    <p>
                        <strong>Status:</strong>
                        @if (Model.IsCompleted)
                        {
                            <span class="badge bg-success">Completed</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">Pending</span>
                        }
                    </p>
                    
                    <p><strong>Created:</strong> @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</p>
                    @if (Model.UpdatedAt.HasValue)
                    {
                        <p><strong>Updated:</strong> @Model.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm:ss")</p>
                    }
                </div>
            </div>

            <div class="mt-4">
                <a href="@Url.Action("Edit", "Task", new { id = Model.Id })" class="btn btn-warning">Edit</a>
                <a href="@Url.Action("Index", "Task")" class="btn btn-secondary">Back to List</a>
            </div>
        </div>
    </div>
</div>
