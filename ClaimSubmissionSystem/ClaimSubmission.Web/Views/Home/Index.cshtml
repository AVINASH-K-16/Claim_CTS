@{
    ViewData["Title"] = "Home Page";
    bool isAuthenticated = Context.Session.GetString("IsAuthenticated") == "true";
}

<div class="text-center">
    @if (isAuthenticated)
    {
        <h1 class="display-4">Welcome, @Context.Session.GetString("FullName")!</h1>
        <p class="lead">You are logged in to the Claim Submission System</p>
        <div class="mt-4">
            <a href="@Url.Action("List", "Claim")" class="btn btn-primary btn-lg mx-2">
                <i class="bi bi-list-check"></i> View Claims
            </a>
            <a href="@Url.Action("Add", "Claim")" class="btn btn-success btn-lg mx-2">
                <i class="bi bi-plus-circle"></i> Add New Claim
            </a>
        </div>
    }
    else
    {
        <h1 class="display-4">Welcome to Claim Submission System</h1>
        <p class="lead">Please log in to access the system</p>
        <div class="mt-4">
            <a href="@Url.Action("Login", "Authentication")" class="btn btn-primary btn-lg">
                <i class="bi bi-box-arrow-in-right"></i> Login
            </a>
        </div>
        <p class="mt-4">Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
    }
</div>
